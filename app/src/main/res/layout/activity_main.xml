<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fundo"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/onepieceposter"
        android:layout_width="411dp"
        android:layout_height="409dp"
        android:layout_marginBottom="4dp"
        android:src="@drawable/onepiece"
        app:layout_constraintBottom_toBottomOf="@+id/assistir"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/logo"
        android:layout_width="57dp"
        android:layout_height="72dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/logo"
        tools:ignore="ContentDescription" />

    <Button
        android:id="@+id/detalhe"
        android:layout_width="132dp"
        android:layout_height="73dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="4dp"
        android:backgroundTint="@android:color/transparent"
        android:text="DETALHES"
        android:textSize="16sp"
        app:icon="@drawable/infocirclesvgrepocom"
        app:iconGravity="textTop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/liveaction"
        tools:ignore="HardcodedText" />

    <Button
        android:id="@+id/assistir"
        android:layout_width="166dp"
        android:layout_height="56dp"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="8dp"
        android:drawableTint="@color/white"
        android:text="Assistir"
        android:textSize="25sp"
        app:icon="@drawable/playsvgrepocom"
        app:layout_constraintEnd_toStartOf="@+id/detalhe"
        app:layout_constraintHorizontal_bias="0.181"
        app:layout_constraintStart_toEndOf="@+id/botaolista"
        app:layout_constraintTop_toBottomOf="@+id/acao"
        tools:ignore="TextSizeCheck,TextSizeCheck,TextSizeCheck,HardcodedText" />

    <TextView
        android:id="@+id/lista"
        android:layout_width="99dp"
        android:layout_height="24dp"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="52dp"
        android:text="Minha Lista"
        android:textColor="@color/white"
        android:textSize="17sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="HardcodedText"/>

    <ImageView
        android:id="@+id/titulofilme"
        android:layout_width="193dp"
        android:layout_height="44dp"
        android:layout_marginTop="108dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription"
        app:srcCompat="@drawable/onepiecelogo" />

    <Button
        android:id="@+id/botaolista"
        android:layout_width="117dp"
        android:layout_height="83dp"
        android:layout_marginTop="8dp"

        android:backgroundTint="@android:color/transparent"
        android:text="MINHA LISTA"
        android:textSize="16sp"
        app:icon="@drawable/plussvgrepocom"
        app:iconGravity="textTop"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/aventura"

        tools:ignore="TextSizeCheck,HardcodedText" />

    <TextView
        android:id="@+id/lancamento"
        android:layout_width="101dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:text="Lançamento"
        android:textColor="@color/white"
        android:textSize="17sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/botaolista"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/liveaction"
        android:layout_width="86dp"
        android:layout_height="26dp"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="44dp"
        android:text="Live-Action"
        android:textColor="@color/white"
        android:textSize="17sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titulofilme"
        tools:ignore="HardcodedText"/>

    <TextView
        android:id="@+id/aventura"
        android:layout_width="72dp"
        android:layout_height="25dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="56dp"
        android:text="Aventura"
        android:textColor="@color/white"
        android:textSize="17sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titulofilme"
        tools:ignore="HardcodedText"/>

    <TextView
        android:id="@+id/series"
        android:layout_width="52dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="44dp"
        android:text="Séries"
        android:textColor="@color/white"
        android:textSize="17sp"
        app:layout_constraintEnd_toStartOf="@+id/filme"
        app:layout_constraintHorizontal_bias="0.222"
        app:layout_constraintStart_toEndOf="@+id/logo"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="HardcodedText"/>

    <TextView
        android:id="@+id/acao"
        android:layout_width="64dp"
        android:layout_height="30dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="52dp"
        android:text="Ação"
        android:textColor="@color/white"
        android:textSize="17sp"
        app:layout_constraintEnd_toStartOf="@+id/liveaction"
        app:layout_constraintHorizontal_bias="0.449"
        app:layout_constraintStart_toEndOf="@+id/aventura"
        app:layout_constraintTop_toBottomOf="@+id/titulofilme"
        tools:ignore="HardcodedText"/>

    <TextView
        android:id="@+id/filme"
        android:layout_width="52dp"
        android:layout_height="24dp"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="32dp"
        android:text="Filmes"
        android:textColor="@color/white"
        android:textSize="17sp"
        app:layout_constraintBottom_toTopOf="@+id/titulofilme"
        app:layout_constraintEnd_toStartOf="@+id/lista"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        tools:ignore="HardcodedText" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.82" />



    <androidx.constraintlayout.widget.Barrier
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top" />

    <androidx.constraintlayout.widget.Barrier
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top" />

    <androidx.constraintlayout.widget.Barrier
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top" />

    <androidx.constraintlayout.widget.Barrier
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="left" />


    <ImageView
        android:id="@+id/strangerthings"
        android:layout_width="104dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="28dp"
        app:layout_constraintBottom_toBottomOf="@+id/demolidor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lancamento"
        app:layout_constraintVertical_bias="1.0"
        app:srcCompat="@drawable/strangerthings"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/demolidor"
        android:layout_width="104dp"
        android:layout_height="59dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="76dp"
        app:layout_constraintBottom_toBottomOf="@+id/scream"
        app:layout_constraintEnd_toStartOf="@+id/scream"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@+id/strangerthings"
        app:layout_constraintTop_toBottomOf="@+id/assistir"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/demolidor"
        tools:ignore="ContentDescription"/>

    <ImageView
        android:id="@+id/scream"
        android:layout_width="113dp"
        android:layout_height="62dp"
        android:layout_marginTop="76dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/detalhe"
        app:srcCompat="@drawable/scream"
        tools:ignore="ContentDescription" />


</androidx.constraintlayout.widget.ConstraintLayout>